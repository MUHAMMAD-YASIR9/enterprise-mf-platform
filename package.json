{
  "name": "enterprise-mf-platform",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve shell",
    "start:shell": "ng serve shell",
    "start:mfe-dashboard": "ng serve mfe-dashboard",
    "start:mfe-orders": "ng serve mfe-orders",
    "start:mfe-admin": "ng serve mfe-admin",
    "start:all": "node scripts/start-all.cjs",
    "build": "ng build shell",
    "build:all": "ng run shell:build && ng run mfe-dashboard:build && ng run mfe-orders:build && ng run mfe-admin:build",
    "watch": "ng build shell --watch --configuration development",
    "test": "ng test shell --watch=false",
    "test:all": "ng test shell --watch=false && ng test mfe-dashboard --watch=false && ng test mfe-orders --watch=false && ng test mfe-admin --watch=false"
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.4",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@napi-rs/magic-string-win32-x64-msvc": "^0.3.4",
    "@primeuix/themes": "^2.0.3",
    "@softarc/native-federation-node": "^3.5.5",
    "es-module-shims": "^1.5.12",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.4",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^21.2.3",
    "@angular-devkit/build-angular": "^21.2.5",
    "@angular/build": "^21.2.5",
    "@angular/cli": "^21.2.5",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
